# ─────────────────────────────────────────────
# AI Gateway — Environment Variables
# Copy this file to .env and fill in all values
# ─────────────────────────────────────────────

# ── Telegram ──────────────────────────────────
# Get token from @BotFather on Telegram (/newbot)
TELEGRAM_BOT_TOKEN=

# Your Telegram numeric user ID — get it from @userinfobot
TELEGRAM_ALLOWED_USER_ID=

# Secret token embedded in the webhook URL path (any random string)
WEBHOOK_SECRET=change-me-to-a-random-string

# ── Email / IMAP ──────────────────────────────
# IMAP server (SSL, port 993)
IMAP_HOST=mail.example.com
IMAP_PORT=993
IMAP_USER=ai@example.com
IMAP_PASS=

# ── Email / SMTP ──────────────────────────────
# SMTP server for sending replies (STARTTLS, port 587)
SMTP_HOST=mail.example.com
SMTP_PORT=587
SMTP_USER=ai@example.com
SMTP_PASS=
SMTP_FROM=ai@example.com

# Comma-separated list of domains allowed to email in
# Emails from other domains are silently dropped
ALLOWED_EMAIL_DOMAINS=example.com

# ── GitHub ────────────────────────────────────
# Path to the SSH private key used for git operations
GITHUB_SSH_KEY=/opt/ai-gateway/.ssh/id_github_gateway

# Your GitHub username
GITHUB_USER=your-github-username

# Git commit identity used when the gateway commits changes
GIT_USER_NAME=ai-gateway
GIT_USER_EMAIL=ai@example.com

# Repos to make available — format: name:git@github.com:user/repo.git
# Separate multiple repos with commas
REPOS=my-docs:git@github.com:youruser/my-docs.git

# ── Gateway ───────────────────────────────────
# Port the Express server listens on
PORT=3000

# Public HTTPS URL for your gateway (used to register the Telegram webhook)
PUBLIC_URL=https://ai-gateway.example.com

# Log level: error | warn | info | debug
LOG_LEVEL=info

# ── AI CLIs ───────────────────────────────────
# Required for Gemini CLI — allows it to run in non-interactive directories
GEMINI_CLI_TRUST_WORKSPACE=true

# ── Memory / History ──────────────────────────
# Path to shared memory file (all AIs read this on every request)
MEMORY_FILE=/opt/ai-gateway/memory.md

# Directory for per-channel conversation history
HISTORY_DIR=/opt/ai-gateway/history
